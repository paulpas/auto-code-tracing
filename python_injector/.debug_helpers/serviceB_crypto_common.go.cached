  "original_hash": "93a19a59659e2b170faf8f2b43b69d435e399008fb07219aa7495fe8dd980d87",
  "instrumented_code": "// crypto_common.go\npackage main\n\nimport (\n\t\"crypto/aes\"\n\t\"crypto/cipher\"\n\t\"crypto/rand\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"runtime\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n)\n\nconst serviceName = \"serviceB\"\n\nvar debugTimings sync.Map\n\nfunc debugEnabled() bool {\n\tenvVars := []string{\"DEBUG\", \"TRACE\", \"VERBOSE\", \"DEBUG_MODE\"}\n\tfor _, v := range envVars {\n\t\tval := os.Getenv(v)\n\t\tif strings.EqualFold(val, \"true\") || strings.EqualFold(val, \"enabled\") {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc currentTimestamp() int64 {\n\treturn time.Now().UnixNano()\n}\n\nfunc getMemoryUsage() uint64 {\n\tvar m runtime.MemStats\n\truntime.ReadMemStats(&m)\n\treturn m.Alloc\n}\n\nfunc debug_enter(name string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tdebugTimings.Store(name, ts)\n\tfmt.Printf(\"[TELEMETRY|%s|%d] ENTER: %s\\n\", serviceName, ts, name)\n}\n\nfunc debug_exit(name string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tendTs := currentTimestamp()\n\tstartVal, ok := debugTimings.Load(name)\n\tvar durationMicros int64\n\tif ok {\n\t\tstartTs := startVal.(int64)\n\t\tdurationMicros = (endTs - startTs) / 1000\n\t}\n\tmem := getMemoryUsage()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] EXIT: %s | duration=%d\u00b5s | mem=%dB\\n\", serviceName, endTs, name, durationMicros, mem)\n}\n\nfunc debug_sub(name string, fn func()) {\n\tif !debugEnabled() {\n\t\tfn()\n\t\treturn\n\t}\n\tdebug_enter(name)\n\tfn()\n\tdebug_exit(name)\n}\n\nfunc debug_data_flow(direction, dataType string, size int, destination string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] DATA-FLOW: %s | type=%s | size=%d | dest=%s\\n\", serviceName, ts, direction, dataType, size, destination)\n}\n\nfunc debug_memory() {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tmem := getMemoryUsage()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] MEMORY: usage=%dB\\n\", serviceName, ts, mem)\n}\n\nfunc debug_network_call(method, url string, requestSize, responseSize int, duration time.Duration) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] NETWORK: method=%s url=%s reqSize=%d respSize=%d duration=%d\u00b5s\\n\",\n\t\tserviceName, ts, method, url, requestSize, responseSize, duration.Microseconds())\n}\n\nfunc debug_error(context string, err error) {\n\tif !debugEnabled() || err == nil {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] ERROR: %s | %v\\n\", serviceName, ts, context, err)\n}\n\n// 32\u2011byte (256\u2011bit) symmetric key \u2013 **DO NOT** ship this in production!\nvar sharedKey = []byte{\n\t0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,\n\t0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f,\n\t0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,\n\t0x18, 0x19, 0x1a, 0x1b, 0x1c, 0x1d, 0x1e, 0x1f,\n}\n\n// encryptAESGCM encrypts plaintext with AES\u2011GCM.\n// Returns (nonce || ciphertext) \u2013 the nonce is needed for decryption.\nfunc encryptAESGCM(plain []byte) ([]byte, error) {\n\tdebug_enter(\"encryptAESGCM\")\n\tdefer debug_exit(\"encryptAESGCM\")\n\n\tdebug_memory()\n\tblock, err := aes.NewCipher(sharedKey)\n\tif err != nil {\n\t\tdebug_error(\"encryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tdebug_memory()\n\n\taesgcm, err := cipher.NewGCM(block)\n\tif err != nil {\n\t\tdebug_error(\"encryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tnonce := make([]byte, aesgcm.NonceSize())\n\tif _, err = io.ReadFull(rand.Reader, nonce); err != nil {\n\t\tdebug_error(\"encryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tciphertext := aesgcm.Seal(nil, nonce, plain, nil)\n\tresult := append(nonce, ciphertext...)\n\tdebug_data_flow(\"out\", \"bytes\", len(result), \"encryptAESGCM\")\n\treturn result, nil\n}\n\n// decryptAESGCM expects (nonce || ciphertext) as produced by encryptAESGCM.\nfunc decryptAESGCM(data []byte) ([]byte, error) {\n\tdebug_enter(\"decryptAESGCM\")\n\tdefer debug_exit(\"decryptAESGCM\")\n\n\tdebug_memory()\n\tblock, err := aes.NewCipher(sharedKey)\n\tif err != nil {\n\t\tdebug_error(\"decryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tdebug_memory()\n\n\taesgcm, err := cipher.NewGCM(block)\n\tif err != nil {\n\t\tdebug_error(\"decryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tnonceSize := aesgcm.NonceSize()\n\tif len(data) < nonceSize {\n\t\terr = fmt.Errorf(\"data too short\")\n\t\tdebug_error(\"decryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tnonce, ciphertext := data[:nonceSize], data[nonceSize:]\n\tplain, err := aesgcm.Open(nil, nonce, ciphertext, nil)\n\tif err != nil {\n\t\tdebug_error(\"decryptAESGCM\", err)\n\t\treturn nil, err\n\t}\n\tdebug_data_flow(\"out\", \"bytes\", len(plain), \"decryptAESGCM\")\n\treturn plain, nil\n}",
