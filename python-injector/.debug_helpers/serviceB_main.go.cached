  "instrumented_code": "// serviceB/main.go\npackage main\n\nimport (\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"net/http\"\n\t\"os\"\n\t\"runtime\"\n\t\"sync\"\n\t\"time\"\n)\n\ntype WorkRequest struct {\n\tCipher string `json:\"cipher\"`\n}\ntype WorkResponse struct {\n\tResult string `json:\"result\"`\n}\n\n/* ---------- Debug Utilities ---------- */\n\nvar (\n\ttelemetryStack = struct {\n\t\tsync.Mutex\n\t\ttimes []int64\n\t}{}\n\tserviceName = \"serviceB\"\n)\n\nfunc debugEnabled() bool {\n\tenvVars := []string{\"DEBUG\", \"TRACE\", \"VERBOSE\", \"DEBUG_MODE\"}\n\tfor _, v := range envVars {\n\t\tval := os.Getenv(v)\n\t\tif val == \"true\" || val == \"enabled\" || val == \"TRUE\" || val == \"ENABLED\" {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc currentTimestamp() int64 {\n\treturn time.Now().UnixNano()\n}\n\nfunc currentMemoryUsage() uint64 {\n\tvar m runtime.MemStats\n\truntime.ReadMemStats(&m)\n\treturn m.Alloc\n}\n\nfunc logTelemetry(level, name, details string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] %s: %s - %s\\n\", serviceName, ts, level, name, details)\n}\n\nfunc debug_enter(name string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tts := currentTimestamp()\n\ttelemetryStack.Lock()\n\ttelemetryStack.times = append(telemetryStack.times, ts)\n\ttelemetryStack.Unlock()\n\tlogTelemetry(\"ENTER\", name, fmt.Sprintf(\"timestamp=%d\", ts))\n}\n\nfunc debug_exit(name string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tend := currentTimestamp()\n\ttelemetryStack.Lock()\n\tvar start int64\n\tif len(telemetryStack.times) > 0 {\n\t\tstart = telemetryStack.times[len(telemetryStack.times)-1]\n\t\ttelemetryStack.times = telemetryStack.times[:len(telemetryStack.times)-1]\n\t}\n\ttelemetryStack.Unlock()\n\tduration := end - start\n\tmem := currentMemoryUsage()\n\tlogTelemetry(\"EXIT\", name, fmt.Sprintf(\"duration=%dns memory=%dbytes\", duration, mem))\n}\n\nfunc debug_sub(name string, fn func()) {\n\tdebug_enter(name)\n\tdefer debug_exit(name)\n\tfn()\n}\n\nfunc debug_data_flow(direction, dataType string, size int, destination string) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tlogTelemetry(\"DATA-FLOW\", destination, fmt.Sprintf(\"direction=%s type=%s size=%d\", direction, dataType, size))\n}\n\nfunc debug_memory() {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tmem := currentMemoryUsage()\n\tlogTelemetry(\"MEMORY\", \"memory_usage\", fmt.Sprintf(\"alloc=%dbytes\", mem))\n}\n\nfunc debug_network_call(method, url string, requestSize, responseSize int, duration int64) {\n\tif !debugEnabled() {\n\t\treturn\n\t}\n\tlogTelemetry(\"NETWORK\", method, fmt.Sprintf(\"url=%s reqSize=%d respSize=%d duration=%dns\", url, requestSize, responseSize, duration))\n}\n\n/* ---------- 1\ufe0f\u20e3 transform (plain data) ---------- */\nfunc transform(payload string) string {\n\tdebug_enter(\"transform\")\n\tdefer debug_exit(\"transform\")\n\n\tresult := fmt.Sprintf(\"transformed[%s]\", payload)\n\tdebug_data_flow(\"output\", \"string\", len(result), \"transform\")\n\treturn result\n}\n\n/* ---------- 2\ufe0f\u20e3 store (no\u2011op) ---------- */\nfunc store(data string) error {\n\tdebug_enter(\"store\")\n\tdefer debug_exit(\"store\")\n\n\t// In a real system you would write to a DB.\n\tdebug_memory()\n\treturn nil\n}\n\n/* ---------- 3\ufe0f\u20e3 respond ---------- */\nfunc respond(w http.ResponseWriter, data string) {\n\tdebug_enter(\"respond\")\n\tdefer debug_exit(\"respond\")\n\n\tresp := WorkResponse{Result: data}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tdebug_data_flow(\"output\", \"json\", len(data), \"respond\")\n\tjson.NewEncoder(w).Encode(resp)\n}\n\n/* ---------- HTTP entry point ---------- */\nfunc workHandler(w http.ResponseWriter, r *http.Request) {\n\tdebug_enter(\"workHandler\")\n\tdefer debug_exit(\"workHandler\")\n\n\tvar req WorkRequest\n\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n\t\thttp.Error(w, \"bad json\", http.StatusBadRequest)\n\t\treturn\n\t}\n\tdebug_data_flow(\"input\", \"json\", len(req.Cipher), \"workHandler\")\n\n\t// Decode base64 ciphertext\n\tcipherBytes, err := base64.StdEncoding.DecodeString(req.Cipher)\n\tif err != nil {\n\t\thttp.Error(w, \"base64 decode error: \"+err.Error(), http.StatusBadRequest)\n\t\treturn\n\t}\n\tdebug_data_flow(\"output\", \"bytes\", len(cipherBytes), \"base64_decode\")\n\tdebug_memory()\n\n\tplainBytes, err := decryptAESGCM(cipherBytes)\n\tif err != nil {\n\t\thttp.Error(w, \"decryption error: \"+err.Error(), http.StatusBadRequest)\n\t\treturn\n\t}\n\tdebug_data_flow(\"output\", \"bytes\", len(plainBytes), \"decryptAESGCM\")\n\tplain := string(plainBytes)\n\n\t// Run original business logic on the plain payload\n\tt := transform(plain)\n\tif err := store(t); err != nil {\n\t\thttp.Error(w, \"store error: \"+err.Error(), http.StatusInternalServerError)\n\t\treturn\n\t}\n\trespond(w, t)\n}\n\n/* ---------- main ---------- */\nfunc main() {\n\tdebug_enter(\"main\")\n\tdefer debug_exit(\"main\")\n\n\thttp.HandleFunc(\"/work\", workHandler)\n\tlog.Println(\"serviceB listening on :8082\")\n\n\tstart := time.Now()\n\terr := http.ListenAndServe(\":8082\", nil)\n\tduration := time.Since(start).Nanoseconds()\n\tif err != nil {\n\t\tlog.Fatalf(\"ListenAndServe error: %v\", err)\n\t}\n\tdebug_network_call(\"LISTEN\", \":8082\", 0, 0, duration)\n}",
