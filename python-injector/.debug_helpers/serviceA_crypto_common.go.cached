  "original_file": "/data/git/ideas/auto-code-tracing/serviceA/crypto_common.go",
  "original_hash": "93a19a59659e2b170faf8f2b43b69d435e399008fb07219aa7495fe8dd980d87",
  "instrumented_code": "// crypto_common.go\npackage main\n\nimport (\n\t\"crypto/aes\"\n\t\"crypto/cipher\"\n\t\"crypto/rand\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"runtime\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n)\n\nvar (\n\tsharedKey = []byte{\n\t\t0x00, 0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07,\n\t\t0x08, 0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f,\n\t\t0x10, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17,\n\t\t0x18, 0x19, 0x1a, 0x1b, 0x1c, 0x1d, 0x1e, 0x1f,\n\t}\n\tserviceName = getServiceName()\n)\n\n// ---------- Debug utilities ----------\nvar (\n\tdebugEnabled bool\n\tstartTimes   = make(map[string]int64)\n\tmu           sync.Mutex\n)\n\nfunc init() {\n\tdebugEnabled = isDebugEnabled()\n}\n\nfunc isDebugEnabled() bool {\n\tvars := []string{\"TRACE\", \"DEBUG_MODE\", \"VERBOSE\", \"DEBUG\"}\n\tfor _, v := range vars {\n\t\tval := strings.ToLower(os.Getenv(v))\n\t\tif val == \"true\" || val == \"enabled\" {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\nfunc getServiceName() string {\n\tif s := os.Getenv(\"SERVICE_NAME\"); s != \"\" {\n\t\treturn s\n\t}\n\treturn \"serviceA\"\n}\n\nfunc logTelemetry(level, name, details string) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tts := time.Now().UnixNano()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] %s: %s - %s\\n\", serviceName, ts, level, name, details)\n}\n\nfunc debug_enter(name string) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tmu.Lock()\n\tstartTimes[name] = time.Now().UnixNano()\n\tmu.Unlock()\n\tvar mem runtime.MemStats\n\truntime.ReadMemStats(&mem)\n\tlogTelemetry(\"ENTER\", name, fmt.Sprintf(\"memory=%dB\", mem.Alloc))\n}\n\nfunc debug_exit(name string) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tend := time.Now().UnixNano()\n\tmu.Lock()\n\tstart, ok := startTimes[name]\n\tif ok {\n\t\tdelete(startTimes, name)\n\t}\n\tmu.Unlock()\n\tvar duration int64\n\tif ok {\n\t\tduration = end - start\n\t}\n\tvar mem runtime.MemStats\n\truntime.ReadMemStats(&mem)\n\tlogTelemetry(\"EXIT\", name, fmt.Sprintf(\"duration=%dns memory=%dB\", duration, mem.Alloc))\n}\n\nfunc debug_sub(name string, fn func()) {\n\tif !debugEnabled {\n\t\tfn()\n\t\treturn\n\t}\n\tdebug_enter(name)\n\tfn()\n\tdebug_exit(name)\n}\n\nfunc debug_data_flow(direction, dataType string, size int, destination string) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tlogTelemetry(\"DATA-FLOW\", destination, fmt.Sprintf(\"%s %s size=%dB\", direction, dataType, size))\n}\n\nfunc debug_memory(name string) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tvar mem runtime.MemStats\n\truntime.ReadMemStats(&mem)\n\tlogTelemetry(\"MEMORY\", name, fmt.Sprintf(\"alloc=%dB total=%dB sys=%dB\", mem.Alloc, mem.TotalAlloc, mem.Sys))\n}\n\nfunc debug_network_call(method, url string, requestSize, responseSize int, duration int64) {\n\tif !debugEnabled {\n\t\treturn\n\t}\n\tlogTelemetry(\"NETWORK\", method, fmt.Sprintf(\"url=%s reqSize=%dB respSize=%dB duration=%dns\", url, requestSize, responseSize, duration))\n}\n\nfunc debug_error(err error, context string) {\n\tif !debugEnabled || err == nil {\n\t\treturn\n\t}\n\tlogTelemetry(\"ERROR\", context, err.Error())\n}\n\n// ---------- Crypto functions ----------\nfunc encryptAESGCM(plain []byte) ([]byte, error) {\n\tdebug_enter(\"encryptAESGCM\")\n\tdefer debug_exit(\"encryptAESGCM\")\n\n\tdebug_data_flow(\"IN\", \"[]byte\", len(plain), \"encryptAESGCM\")\n\tdebug_memory(\"encryptAESGCM - start\")\n\n\tblock, err := aes.NewCipher(sharedKey)\n\tif err != nil {\n\t\tdebug_error(err, \"encryptAESGCM - NewCipher\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"encryptAESGCM - after NewCipher\")\n\n\taesgcm, err := cipher.NewGCM(block)\n\tif err != nil {\n\t\tdebug_error(err, \"encryptAESGCM - NewGCM\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"encryptAESGCM - after NewGCM\")\n\n\tnonce := make([]byte, aesgcm.NonceSize())\n\tif _, err = io.ReadFull(rand.Reader, nonce); err != nil {\n\t\tdebug_error(err, \"encryptAESGCM - ReadFull\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"encryptAESGCM - after nonce generation\")\n\n\tciphertext := aesgcm.Seal(nil, nonce, plain, nil)\n\tresult := append(nonce, ciphertext...)\n\tdebug_data_flow(\"OUT\", \"[]byte\", len(result), \"encryptAESGCM\")\n\tdebug_memory(\"encryptAESGCM - end\")\n\treturn result, nil\n}\n\nfunc decryptAESGCM(data []byte) ([]byte, error) {\n\tdebug_enter(\"decryptAESGCM\")\n\tdefer debug_exit(\"decryptAESGCM\")\n\n\tdebug_data_flow(\"IN\", \"[]byte\", len(data), \"decryptAESGCM\")\n\tdebug_memory(\"decryptAESGCM - start\")\n\n\tblock, err := aes.NewCipher(sharedKey)\n\tif err != nil {\n\t\tdebug_error(err, \"decryptAESGCM - NewCipher\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"decryptAESGCM - after NewCipher\")\n\n\taesgcm, err := cipher.NewGCM(block)\n\tif err != nil {\n\t\tdebug_error(err, \"decryptAESGCM - NewGCM\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"decryptAESGCM - after NewGCM\")\n\n\tnonceSize := aesgcm.NonceSize()\n\tif len(data) < nonceSize {\n\t\terr = fmt.Errorf(\"ciphertext too short\")\n\t\tdebug_error(err, \"decryptAESGCM - nonce size check\")\n\t\treturn nil, err\n\t}\n\tnonce, ciphertext := data[:nonceSize], data[nonceSize:]\n\n\tplain, err := aesgcm.Open(nil, nonce, ciphertext, nil)\n\tif err != nil {\n\t\tdebug_error(err, \"decryptAESGCM - Open\")\n\t\treturn nil, err\n\t}\n\tdebug_memory(\"decryptAESGCM - after Open\")\n\n\tdebug_data_flow(\"OUT\", \"[]byte\", len(plain), \"decryptAESGCM\")\n\tdebug_memory(\"decryptAESGCM - end\")\n\treturn plain, nil\n}",
