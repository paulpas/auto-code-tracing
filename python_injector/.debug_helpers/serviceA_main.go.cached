  "instrumented_code": "// serviceA/main.go\npackage main\n\nimport (\n\t\"bytes\"\n\t\"encoding/base64\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"io\"\n\t\"log\"\n\t\"net/http\"\n\t\"os\"\n\t\"runtime\"\n\t\"sync\"\n\t\"time\"\n)\n\nvar (\n\tdebugEnvVars = []string{\"TRACE\", \"DEBUG_MODE\", \"VERBOSE\", \"DEBUG\"}\n\tserviceName  = getServiceName()\n\tstartTimes   = struct {\n\t\tsync.Mutex\n\t\tm map[string]time.Time\n\t}{m: make(map[string]time.Time)}\n)\n\nfunc getServiceName() string {\n\tif v := os.Getenv(\"SERVICE_NAME\"); v != \"\" {\n\t\treturn v\n\t}\n\treturn \"serviceA\"\n}\n\nfunc isDebugEnabled() bool {\n\tfor _, v := range debugEnvVars {\n\t\tif val := os.Getenv(v); val != \"\" {\n\t\t\tswitch val {\n\t\t\tcase \"true\", \"enabled\", \"TRUE\", \"ENABLED\":\n\t\t\t\treturn true\n\t\t\t}\n\t\t}\n\t}\n\treturn false\n}\n\nfunc logTelemetry(level, name, details string) {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tts := time.Now().UnixNano()\n\tfmt.Printf(\"[TELEMETRY|%s|%d] %s: %s - %s\\n\", serviceName, ts, level, name, details)\n}\n\nfunc debug_enter(name string) {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tstartTimes.Lock()\n\tstartTimes.m[name] = time.Now()\n\tstartTimes.Unlock()\n\tlogTelemetry(\"ENTER\", name, \"entering function\")\n}\n\nfunc debug_exit(name string) {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tstartTimes.Lock()\n\tstart, ok := startTimes.m[name]\n\tif ok {\n\t\tdelete(startTimes.m, name)\n\t}\n\tstartTimes.Unlock()\n\tif ok {\n\t\tduration := time.Since(start)\n\t\tlogTelemetry(\"EXIT\", name, fmt.Sprintf(\"duration=%d\u00b5s\", duration.Microseconds()))\n\t} else {\n\t\tlogTelemetry(\"EXIT\", name, \"no start time recorded\")\n\t}\n}\n\nfunc debug_sub(name string, fn func()) {\n\tif !isDebugEnabled() {\n\t\tfn()\n\t\treturn\n\t}\n\tdebug_enter(name)\n\tdefer debug_exit(name)\n\tfn()\n}\n\nfunc debug_data_flow(direction, dataType string, size int, destination string) {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tlogTelemetry(\"DATA-FLOW\", direction, fmt.Sprintf(\"type=%s size=%d dest=%s\", dataType, size, destination))\n}\n\nfunc debug_memory() {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tvar m runtime.MemStats\n\truntime.ReadMemStats(&m)\n\tlogTelemetry(\"MEMORY\", \"memory_usage\", fmt.Sprintf(\"alloc=%d heapIdle=%d heapInuse=%d\", m.Alloc, m.HeapIdle, m.HeapInuse))\n}\n\nfunc debug_network_call(method, url string, requestSize, responseSize int, duration time.Duration) {\n\tif !isDebugEnabled() {\n\t\treturn\n\t}\n\tlogTelemetry(\"NETWORK\", fmt.Sprintf(\"%s %s\", method, url),\n\t\tfmt.Sprintf(\"reqSize=%d respSize=%d duration=%d\u00b5s\", requestSize, responseSize, duration.Microseconds()))\n}\n\nfunc debug_error(name string, err error) {\n\tif !isDebugEnabled() || err == nil {\n\t\treturn\n\t}\n\tlogTelemetry(\"ERROR\", name, err.Error())\n}\n\n/* ---------- 1\ufe0f\u20e3 validate ---------- */\nfunc validate(input string) error {\n\tdebug_enter(\"validate\")\n\tdefer debug_exit(\"validate\")\n\n\tif input == \"\" {\n\t\terr := fmt.Errorf(\"empty input\")\n\t\tdebug_error(\"validate\", err)\n\t\treturn err\n\t}\n\treturn nil\n}\n\n/* ---------- 2\ufe0f\u20e3 enrich ---------- */\nfunc enrich(input string) string {\n\tdebug_enter(\"enrich\")\n\tdefer debug_exit(\"enrich\")\n\n\tdebug_data_flow(\"in\", \"string\", len(input), \"enrich\")\n\tresult := fmt.Sprintf(\"%s|ts=%d\", input, time.Now().Unix())\n\tdebug_data_flow(\"out\", \"string\", len(result), \"enrich\")\n\treturn result\n}\n\n/* ---------- 3\ufe0f\u20e3 call serviceB (encrypt + send) ---------- */\nfunc callServiceB(plainPayload string) (string, error) {\n\tdebug_enter(\"callServiceB\")\n\tdefer debug_exit(\"callServiceB\")\n\n\t// Encryption\n\tcipherBytes, err := encryptAESGCM([]byte(plainPayload))\n\tif err != nil {\n\t\tdebug_error(\"callServiceB\", err)\n\t\treturn \"\", fmt.Errorf(\"encryption failed: %w\", err)\n\t}\n\tdebug_memory()\n\tdebug_data_flow(\"out\", \"bytes\", len(cipherBytes), \"encrypted payload\")\n\n\tencoded := base64.StdEncoding.EncodeToString(cipherBytes)\n\tdebug_data_flow(\"out\", \"string\", len(encoded), \"base64 encoded\")\n\n\tworkReq := struct {\n\t\tCipher string `json:\"cipher\"`\n\t}{Cipher: encoded}\n\tbody, err := json.Marshal(workReq)\n\tif err != nil {\n\t\tdebug_error(\"callServiceB\", err)\n\t\treturn \"\", err\n\t}\n\tdebug_memory()\n\tdebug_data_flow(\"out\", \"json\", len(body), \"request body\")\n\n\t// Network call with telemetry\n\tstartNet := time.Now()\n\tresp, err := http.Post(\"http://localhost:8082/work\", \"application/json\", bytes.NewReader(body))\n\tnetDuration := time.Since(startNet)\n\tif err != nil {\n\t\tdebug_error(\"callServiceB\", err)\n\t\treturn \"\", err\n\t}\n\tdefer resp.Body.Close()\n\n\trespBody, err := io.ReadAll(resp.Body)\n\tif err != nil {\n\t\tdebug_error(\"callServiceB\", err)\n\t\treturn \"\", err\n\t}\n\tdebug_network_call(\"POST\", \"http://localhost:8082/work\", len(body), len(respBody), netDuration)\n\tdebug_data_flow(\"in\", \"json\", len(respBody), \"response body\")\n\n\tvar workResp struct {\n\t\tResult string `json:\"result\"`\n\t}\n\tif err := json.Unmarshal(respBody, &workResp); err != nil {\n\t\tdebug_error(\"callServiceB\", err)\n\t\treturn \"\", err\n\t}\n\treturn workResp.Result, nil\n}\n\n/* ---------- 4\ufe0f\u20e3 formatResult ---------- */\nfunc formatResult(serviceBResult string) string {\n\tdebug_enter(\"formatResult\")\n\tdefer debug_exit(\"formatResult\")\n\n\tdebug_data_flow(\"in\", \"string\", len(serviceBResult), \"formatResult\")\n\tresult := fmt.Sprintf(\"serviceA processed \u2192 %s\", serviceBResult)\n\tdebug_data_flow(\"out\", \"string\", len(result), \"formatResult\")\n\treturn result\n}\n\n/* ---------- HTTP entry point ---------- */\nfunc processHandler(w http.ResponseWriter, r *http.Request) {\n\tdebug_enter(\"processHandler\")\n\tdefer debug_exit(\"processHandler\")\n\n\tvar in ProcessRequest\n\tif err := json.NewDecoder(r.Body).Decode(&in); err != nil {\n\t\tdebug_error(\"processHandler\", err)\n\t\thttp.Error(w, \"bad json\", http.StatusBadRequest)\n\t\treturn\n\t}\n\tdebug_data_flow(\"in\", \"json\", 0, \"request body\")\n\n\tif err := validate(in.Input); err != nil {\n\t\thttp.Error(w, \"validation error: \"+err.Error(), http.StatusBadRequest)\n\t\treturn\n\t}\n\n\tenriched := enrich(in.Input)\n\n\tb2, err := callServiceB(enriched)\n\tif err != nil {\n\t\thttp.Error(w, \"serviceB call failed: \"+err.Error(), http.StatusBadGateway)\n\t\treturn\n\t}\n\tfinal := formatResult(b2)\n\n\tout := ProcessResponse{Final: final}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tif err := json.NewEncoder(w).Encode(out); err != nil {\n\t\tdebug_error(\"processHandler\", err)\n\t}\n}\n\n/* ---------- main ---------- */\nfunc main() {\n\tdebug_enter(\"main\")\n\tdefer debug_exit(\"main\")\n\n\thttp.HandleFunc(\"/process\", processHandler)\n\tlog.Println(\"serviceA listening on :8081\")\n\tdebug_memory()\n\tlog.Fatal(http.ListenAndServe(\":8081\", nil))\n}\n\n// Placeholder for encryptAESGCM to make the file compile.\nfunc encryptAESGCM(plaintext []byte) ([]byte, error) {\n\t// Dummy implementation; replace with real encryption.\n\treturn plaintext, nil\n}\n\n// Types\ntype ProcessRequest struct{ Input string `json:\"input\"` }\ntype ProcessResponse struct{ Final string `json:\"final\"` }",
